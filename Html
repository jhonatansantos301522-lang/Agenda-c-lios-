<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agenda de Cílios</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-pink-50 to-purple-50">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-xl p-8 max-w-2xl w-full">
            <h1 class="text-4xl font-bold text-pink-600 mb-8 text-center">💅 Agenda de Cílios</h1>
            
            <div class="space-y-4 mb-8">
                <input type="text" id="nome" placeholder="Seu nome" class="w-full px-4 py-3 border-2 border-pink-300 rounded-lg focus:border-pink-500 focus:outline-none">
                <input type="tel" id="telefone" placeholder="Seu WhatsApp" class="w-full px-4 py-3 border-2 border-pink-300 rounded-lg focus:border-pink-500 focus:outline-none">
                <input type="date" id="data" class="w-full px-4 py-3 border-2 border-pink-300 rounded-lg focus:border-pink-500 focus:outline-none">
                <button onclick="agendar()" class="w-full bg-pink-500 text-white py-3 rounded-lg font-bold hover:bg-pink-600">Agendar 🎉</button>
            </div>

            <h2 class="text-2xl font-bold text-gray-800 mb-4">Agendamentos:</h2>
            <div id="lista" class="space-y-2">
                <p class="text-gray-500 text-center">Nenhum agendamento ainda</p>
            </div>
        </div>
    </div>

    <script>
        let agendamentos = JSON.parse(localStorage.getItem('agendamentos') || '[]');

        function agendar() {
            const nome = document.getElementById('nome').value;
            const telefone = document.getElementById('telefone').value;
            const data = document.getElementById('data').value;

            if (nome && telefone && data) {
                agendamentos.push({ nome, telefone, data });
                localStorage.setItem('agendamentos', JSON.stringify(agendamentos));
                document.getElementById('nome').value = '';
                document.getElementById('telefone').value = '';
                document.getElementById('data').value = '';
                mostrarAgendamentos();
                alert('Agendamento realizado! 🎉');
            } else {
                alert('Preencha todos os campos!');
            }
        }

        function mostrarAgendamentos() {
            const lista = document.getElementById('lista');
            if (agendamentos.length === 0) {
                lista.innerHTML = '<p class="text-gray-500 text-center">Nenhum agendamento ainda</p>';
            } else {
                lista.innerHTML = agendamentos.map((a, i) => `
                    <div class="bg-pink-100 p-4 rounded-lg">
                        <p><strong>${a.nome}</strong> - ${a.telefone}</p>
                        <p class="text-sm text-gray-600">${a.data}</p>
                    </div>
                `).join('');
            }
        }

        mostrarAgendamentos();
    </script>
</body>
</html>
